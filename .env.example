# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# WhatsApp Cloud API (Meta for Developers)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=choose-a-random-string
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_API_VERSION=v21.0

# Upstash Redis (used for conversation history + message dedup)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Bot behavior
BOT_SYSTEM_PROMPT=Você é um assistente útil e direto via WhatsApp. Responda em português, de forma curta e clara.
HISTORY_MAX_TURNS=20
