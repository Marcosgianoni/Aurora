# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Zappfy (https://api.zappfy.io)
ZAPPFY_API_BASE_URL=https://api.zappfy.io
ZAPPFY_INSTANCE_TOKEN=

# Slug aleatório no caminho do webhook (Zappfy não assina o webhook).
# Gere algo tipo: openssl rand -hex 24
# URL final fica: https://<seu-app>.vercel.app/api/webhook/<este-valor>
WEBHOOK_SECRET=

# Upstash Redis (histórico de conversa + dedup de mensagens)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Comportamento do bot
BOT_SYSTEM_PROMPT=Você é um assistente útil e direto via WhatsApp. Responda em português, de forma curta e clara.
HISTORY_MAX_TURNS=20
